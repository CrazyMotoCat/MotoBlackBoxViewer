<Window x:Class="MotoBlackBoxViewer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:MotoBlackBoxViewer.App.Controls"
        mc:Ignorable="d"
        Title="Moto Black Box Viewer"
        Height="950"
        Width="1500"
        MinHeight="780"
        MinWidth="1240"
        Background="{StaticResource WindowBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="TableNumberTextStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style x:Key="TableCenterTextStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12"
                Margin="0,0,0,12">
            <WrapPanel VerticalAlignment="Center"
                       ItemHeight="32"
                       Margin="0,0,6,0">
                <Button Style="{StaticResource ToolbarPrimaryButtonStyle}"
                        Content="Импорт CSV"
                        Margin="0,0,6,0"
                        Command="{Binding OpenCsvCommand}" />
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Карта"
                        Margin="0,0,6,0"
                        Command="{Binding RefreshMapCommand}" />
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Браузер"
                        Margin="0,0,8,0"
                        Command="{Binding OpenMapCommand}" />
                <Border Width="1"
                        Height="18"
                        Background="{StaticResource BorderBrushTheme}"
                        Margin="2,7,8,7" />
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Сброс"
                        Margin="0,0,6,0"
                        Command="{Binding ResetFilterCommand}" />
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Очистить"
                        Command="{Binding ClearCommand}" />
                <Border Width="1"
                        Height="18"
                        Background="{StaticResource BorderBrushTheme}"
                        Margin="8,7,8,7" />
                <TextBlock Text="Окно графика"
                           Foreground="{StaticResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox Width="220"
                          Height="28"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding Workspace.Data.ChartWindowOptions}"
                          SelectedItem="{Binding Workspace.Data.SelectedChartWindow, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       Foreground="{StaticResource TextBrushTheme}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Border Width="1"
                        Height="18"
                        Background="{StaticResource BorderBrushTheme}"
                        Margin="8,7,8,7" />
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        MinWidth="150"
                        Content="{Binding Workspace.ChartProfiling.ToggleButtonText}"
                        ToolTip="Developer-facing chart pipeline profiling session"
                        Command="{Binding ToggleChartProfilingCommand}" />
            </WrapPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="1.45*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushTheme}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Маршрут"
                               Foreground="{StaticResource TextBrushTheme}"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Margin="2,0,0,12" />

                    <controls:MapViewControl Grid.Row="1"
                                             RouteJson="{Binding Workspace.Map.RouteJson}"
                                             SelectedPointIndex="{Binding Workspace.Selection.SelectedPointIndex}"
                                             SelectedPointLatitude="{Binding Workspace.Map.SelectedPointLatitude}"
                                             SelectedPointLongitude="{Binding Workspace.Map.SelectedPointLongitude}"
                                             IsPlaybackRunning="{Binding Workspace.Playback.IsPlaybackRunning}"
                                             IsManualScrubbing="{Binding Workspace.Map.IsManualScrubbing}"
                                             RefreshVersion="{Binding Workspace.Map.RefreshVersion}"
                                             ErrorOccurred="MapViewControl_ErrorOccurred" />

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Border Style="{StaticResource OverlayCardStyle}"
                                BorderBrush="{StaticResource SelectedBorderBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Навигация"
                                               Foreground="{StaticResource MutedTextSoftBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Workspace.Playback.PlaybackSpeedSummary}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="11"
                                               Margin="12,0,0,0" />
                                </StackPanel>

                                <Border Grid.Row="0"
                                        Grid.Column="3"
                                        Background="{StaticResource AccentSoftBrush}"
                                        BorderBrush="{StaticResource AccentHairlineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,4"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Workspace.Selection.PlaybackSummary}"
                                               Foreground="{StaticResource SelectedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>

                                <Button Grid.Row="1"
                                        Grid.Column="0"
                                        Content="◀"
                                        Width="34"
                                        Height="28"
                                        Margin="0,10,4,0"
                                        HorizontalAlignment="Left"
                                        IsEnabled="{Binding Workspace.Data.HasPoints}"
                                        Command="{Binding PrevPointCommand}" />
                                <Button Grid.Row="1"
                                        Grid.Column="1"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Content="{Binding Workspace.Playback.PlaybackButtonText}"
                                        MinWidth="84"
                                        Height="28"
                                        Margin="0,10,8,0"
                                        IsEnabled="{Binding Workspace.Data.HasPoints}"
                                        Command="{Binding TogglePlaybackCommand}" />
                                <Slider Grid.Row="1"
                                        Grid.Column="2"
                                        Minimum="{Binding Workspace.Selection.PlaybackMinimum}"
                                        Maximum="{Binding Workspace.Selection.PlaybackMaximum}"
                                        Value="{Binding Workspace.Selection.PlaybackPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PreviewMouseLeftButtonDown="PlaybackSlider_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="PlaybackSlider_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="PlaybackSlider_LostMouseCapture"
                                        IsEnabled="{Binding Workspace.Data.HasPoints}"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1"
                                        SmallChange="1"
                                        LargeChange="1"
                                        VerticalAlignment="Center"
                                        Margin="0,10,10,0"
                                        MinWidth="340" />
                                <StackPanel Grid.Row="1"
                                            Grid.Column="3"
                                            Orientation="Horizontal"
                                            Margin="0,10,0,0">
                                    <ComboBox Width="82"
                                              Height="28"
                                              Margin="0,0,8,0"
                                              ItemsSource="{Binding Workspace.Playback.PlaybackSpeedOptions}"
                                              SelectedItem="{Binding Workspace.Playback.SelectedPlaybackSpeed, Mode=TwoWay}"
                                              IsEnabled="{Binding Workspace.Data.HasPoints}"
                                              VerticalAlignment="Center">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="{StaticResource TextBrushTheme}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <Button Width="34"
                                            Height="28"
                                            Content="▶"
                                            IsEnabled="{Binding Workspace.Data.HasPoints}"
                                            Command="{Binding NextPointCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource OverlayCardStyle}"
                                Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0">
                                    <TextBlock Text="Диапазон точек"
                                               Foreground="{StaticResource TextBrushTheme}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Workspace.Data.FilterSummary}"
                                               Foreground="{StaticResource MutedTextSoftBrush}"
                                               FontSize="11"
                                               Margin="0,3,0,0" />
                                </StackPanel>

                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Content="Сброс"
                                        MinWidth="74"
                                        Height="28"
                                        Opacity="0.9"
                                        Command="{Binding ResetFilterCommand}" />

                                <Grid Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="От"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <Slider Grid.Column="1"
                                            Minimum="{Binding Workspace.Data.FilterMinimum}"
                                            Maximum="{Binding Workspace.Data.FilterMaximum}"
                                            Value="{Binding Workspace.Data.FilterStartIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding Workspace.Data.HasSourceData}"
                                            IsSnapToTickEnabled="True"
                                            TickFrequency="1"
                                            SmallChange="1"
                                            LargeChange="10"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center" />
                                    <Border Grid.Column="2"
                                            Background="{StaticResource SurfaceSubtleBrush}"
                                            BorderBrush="{StaticResource BorderSoftBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,5"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Workspace.Data.FilterStartIndex}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontWeight="SemiBold"
                                                   MinWidth="40"
                                                   TextAlignment="Right" />
                                    </Border>

                                    <TextBlock Grid.Column="4"
                                               Text="До"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <Slider Grid.Column="5"
                                            Minimum="{Binding Workspace.Data.FilterMinimum}"
                                            Maximum="{Binding Workspace.Data.FilterMaximum}"
                                            Value="{Binding Workspace.Data.FilterEndIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding Workspace.Data.HasSourceData}"
                                            IsSnapToTickEnabled="True"
                                            TickFrequency="1"
                                            SmallChange="1"
                                            LargeChange="10"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center" />
                                    <Border Grid.Column="6"
                                            Background="{StaticResource SurfaceSubtleBrush}"
                                            BorderBrush="{StaticResource BorderSoftBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,5"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Workspace.Data.FilterEndIndex}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontWeight="SemiBold"
                                                   MinWidth="40"
                                                   TextAlignment="Right" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="0.8*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource OverlayCardStyle}"
                                    BorderBrush="{StaticResource SelectedBorderBrush}"
                                    Margin="0,0,8,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Выбранная точка"
                                               Foreground="{StaticResource MutedTextSoftBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding Workspace.Selection.SelectedPoint.Index, StringFormat=Исх. #{0}, TargetNullValue=Нет выбора}"
                                               Foreground="{StaticResource SelectedTextBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />

                                    <StackPanel Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Orientation="Horizontal"
                                                Margin="0,8,0,0">
                                        <Border Background="{StaticResource AccentSoftBrush}"
                                                BorderBrush="{StaticResource AccentHairlineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10,6"
                                                Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="Скорость"
                                                           Foreground="{StaticResource MutedTextSoftBrush}"
                                                           FontSize="10" />
                                                <TextBlock Text="{Binding Workspace.Selection.SelectedPoint.SpeedKmh, StringFormat={}{0:F1} км/ч, TargetNullValue=--}"
                                                           Foreground="{StaticResource SelectedTextBrush}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource SurfaceSubtleBrush}"
                                                BorderBrush="{StaticResource BorderSoftBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10,6">
                                            <StackPanel>
                                                <TextBlock Text="Наклон"
                                                           Foreground="{StaticResource MutedTextSoftBrush}"
                                                           FontSize="10" />
                                                <TextBlock Text="{Binding Workspace.Selection.SelectedPoint.LeanAngleDeg, StringFormat={}{0:F1}°, TargetNullValue=--}"
                                                           Foreground="{StaticResource TextBrushTheme}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <UniformGrid Grid.Row="2"
                                                 Grid.ColumnSpan="2"
                                                 Columns="2"
                                                 Margin="0,10,0,0">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Координаты"
                                                       Foreground="{StaticResource MutedTextSoftBrush}"
                                                       FontSize="10" />
                                            <TextBlock Text="{Binding Workspace.Selection.SelectedPoint.Latitude, StringFormat={}{0:F6}, TargetNullValue=--}"
                                                       Foreground="{StaticResource TextBrushTheme}"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding Workspace.Selection.SelectedPoint.Longitude, StringFormat={}{0:F6}, TargetNullValue=--}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12" />
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock Text="Детали"
                                                       Foreground="{StaticResource MutedTextSoftBrush}"
                                                       FontSize="10" />
                                            <TextBlock Text="{Binding Workspace.Selection.SelectedPoint.DistanceFromStartMeters, StringFormat=Дистанция {0:F1} м, TargetNullValue=Дистанция --}"
                                                       Foreground="{StaticResource TextBrushTheme}"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding Workspace.Selection.SelectedPointSummary}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="32" />
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource OverlayCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Подсказка"
                                               Foreground="{StaticResource MutedTextSoftBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Как быстрее смотреть заезд"
                                               Foreground="{StaticResource TextBrushTheme}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="Выберите точку в таблице справа — карта и графики сразу сфокусируются на ней."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="Playback удобно использовать для пошагового просмотра маршрута, а диапазон — чтобы быстро сузить интересный участок."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="Выбранная точка ниже карты показывает ключевые значения без дублирования поверх маршрута."
                                               Foreground="{StaticResource MutedTextSoftBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Column="1"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushTheme}"
                        BorderThickness="1"
                        Padding="10">
                <TabItem Header="Точки">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding Workspace.Data.Points}"
                                  SelectedItem="{Binding Workspace.Selection.SelectedPoint, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource SurfaceAltBrush}"
                                  Foreground="{StaticResource TextBrushTheme}"
                                  BorderThickness="0"
                                  RowHeaderWidth="6">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#"
                                                    Binding="{Binding Index}"
                                                    Width="48"
                                                    ElementStyle="{StaticResource TableCenterTextStyle}" />
                                <DataGridTextColumn Header="Широта"
                                                    Binding="{Binding Latitude, StringFormat=F6}"
                                                    Width="*"
                                                    ElementStyle="{StaticResource TableNumberTextStyle}" />
                                <DataGridTextColumn Header="Долгота"
                                                    Binding="{Binding Longitude, StringFormat=F6}"
                                                    Width="*"
                                                    ElementStyle="{StaticResource TableNumberTextStyle}" />
                                <DataGridTextColumn Header="Скорость"
                                                    Binding="{Binding SpeedKmh, StringFormat=F1}"
                                                    Width="82"
                                                    ElementStyle="{StaticResource TableNumberTextStyle}" />
                                <DataGridTextColumn Header="Наклон"
                                                    Binding="{Binding LeanAngleDeg, StringFormat=F1}"
                                                    Width="82"
                                                    ElementStyle="{StaticResource TableNumberTextStyle}" />
                                <DataGridTextColumn Header="AX"
                                                    Binding="{Binding AccelX, StringFormat=F2}"
                                                    Width="72"
                                                    ElementStyle="{StaticResource TableNumberTextStyle}" />
                                <DataGridTextColumn Header="AY"
                                                    Binding="{Binding AccelY, StringFormat=F2}"
                                                    Width="72"
                                                    ElementStyle="{StaticResource TableNumberTextStyle}" />
                                <DataGridTextColumn Header="AZ"
                                                    Binding="{Binding AccelZ, StringFormat=F2}"
                                                    Width="72"
                                                    ElementStyle="{StaticResource TableNumberTextStyle}" />
                                <DataGridTextColumn Header="Дистанция, м"
                                                    Binding="{Binding DistanceFromStartMeters, StringFormat=F1}"
                                                    Width="110"
                                                    ElementStyle="{StaticResource TableNumberTextStyle}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Скорость">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="График скорости" Foreground="{StaticResource TextBrushTheme}" FontSize="18" Margin="0,0,0,8" />
                            <Border Style="{StaticResource OverlayCardStyle}"
                                    Margin="0,0,0,8">
                                <UniformGrid Columns="3">
                                    <StackPanel>
                                        <TextBlock Text="Текущая точка"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="10" />
                                        <TextBlock Text="{Binding Workspace.Selection.PlaybackSummary}"
                                                   Foreground="{StaticResource SelectedTextBrush}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Средняя скорость"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="10" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.AverageSpeedKmh, StringFormat={}{0:F1} км/ч}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Макс. скорость"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="10" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.MaxSpeedKmh, StringFormat={}{0:F1} км/ч}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </UniformGrid>
                            </Border>
                            <Border Style="{StaticResource ChartCardStyle}">
                                <controls:LineChartControl Values="{Binding Workspace.Data.SpeedSeries}"
                                                           SelectedIndex="{Binding Workspace.Selection.PlaybackPosition}"
                                                           WindowRadius="{Binding Workspace.Data.ChartWindowRadius}"
                                                           Unit="км/ч"
                                                           SeriesLabel="Скорость"
                                                           LineColorHex="#C65A69" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Угол наклона">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="График угла наклона" Foreground="{StaticResource TextBrushTheme}" FontSize="18" Margin="0,0,0,8" />
                            <Border Style="{StaticResource OverlayCardStyle}"
                                    Margin="0,0,0,8">
                                <UniformGrid Columns="3">
                                    <StackPanel>
                                        <TextBlock Text="Выбранная точка"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="10" />
                                        <TextBlock Text="{Binding Workspace.Selection.SelectedPoint.LeanAngleDeg, StringFormat={}{0:F1}°, TargetNullValue=--}"
                                                   Foreground="{StaticResource SelectedTextBrush}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Мин. угол"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="10" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.MinLeanDeg, StringFormat={}{0:F1}°}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Макс. угол"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="10" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.MaxLeanDeg, StringFormat={}{0:F1}°}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </UniformGrid>
                            </Border>
                            <Border Style="{StaticResource ChartCardStyle}">
                                <controls:LineChartControl Values="{Binding Workspace.Data.LeanSeries}"
                                                           SelectedIndex="{Binding Workspace.Selection.PlaybackPosition}"
                                                           WindowRadius="{Binding Workspace.Data.ChartWindowRadius}"
                                                           Unit="°"
                                                           SeriesLabel="Наклон"
                                                           LineColorHex="#9E5662" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Ускорения XYZ">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="График ускорений X / Y / Z" Foreground="{StaticResource TextBrushTheme}" FontSize="18" Margin="0,0,0,8" />
                            <Border Style="{StaticResource OverlayCardStyle}"
                                    Margin="0,0,0,8">
                                <UniformGrid Columns="3">
                                    <StackPanel>
                                        <TextBlock Text="AX / AY / AZ"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="10" />
                                        <TextBlock Text="{Binding Workspace.Selection.SelectedPoint.AccelX, StringFormat=AX {0:F2}, TargetNullValue=AX --}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Workspace.Selection.SelectedPoint.AccelY, StringFormat=AY {0:F2}, TargetNullValue=AY --}"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Workspace.Selection.SelectedPoint.AccelZ, StringFormat=AZ {0:F2}, TargetNullValue=AZ --}"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Текущая точка"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="10" />
                                        <TextBlock Text="{Binding Workspace.Selection.PlaybackSummary}"
                                                   Foreground="{StaticResource SelectedTextBrush}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Диапазон"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="10" />
                                        <TextBlock Text="{Binding Workspace.Data.FilterSummary}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </UniformGrid>
                            </Border>
                            <Border Style="{StaticResource ChartCardStyle}">
                                <controls:MultiLineChartControl Series="{Binding Workspace.Data.AccelSeries}"
                                                                SelectedIndex="{Binding Workspace.Selection.PlaybackPosition}"
                                                                WindowRadius="{Binding Workspace.Data.ChartWindowRadius}"
                                                                Unit="ед." />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Статистика">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Сводка маршрута / диапазона" Foreground="{StaticResource TextBrushTheme}" FontSize="20" Margin="0,0,0,12" />
                        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,12">
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Количество точек" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.PointCount}" Foreground="{StaticResource TextBrushTheme}" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Дистанция, м" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.TotalDistanceMeters, StringFormat=F1}" Foreground="{StaticResource TextBrushTheme}" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Средняя скорость" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.AverageSpeedKmh, StringFormat=F1}" Foreground="{StaticResource TextBrushTheme}" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Макс. скорость" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.MaxSpeedKmh, StringFormat=F1}" Foreground="{StaticResource TextBrushTheme}" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Мин. угол" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.MinLeanDeg, StringFormat=F1}" Foreground="{StaticResource TextBrushTheme}" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Макс. угол" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding Workspace.Data.Statistics.MaxLeanDeg, StringFormat=F1}" Foreground="{StaticResource TextBrushTheme}" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                        </UniformGrid>

                        <StackPanel Grid.Row="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource OverlayCardStyle}"
                                        BorderBrush="{StaticResource SelectedBorderBrush}"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Фокус по выбранной точке"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Workspace.Selection.SelectedPointSummary}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontSize="13"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Style="{StaticResource OverlayCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Сессия и диапазон"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Workspace.Data.CurrentFileName, TargetNullValue=Файл не выбран}"
                                                   Foreground="{StaticResource TextBrushTheme}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,0" />
                                        <TextBlock Text="{Binding Workspace.Data.FilterSummary}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Workspace.Data.ImportDiagnosticsText}"
                                                   Foreground="{StaticResource SelectedTextBrush}"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding Workspace.Data.HasImportDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding Workspace.Data.StatusText}"
                                                   Foreground="{StaticResource MutedTextSoftBrush}"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Style="{StaticResource OverlayCardStyle}"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding Workspace.ChartProfiling.IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Chart Pipeline Profiling"
                                               Foreground="{StaticResource TextBrushTheme}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Workspace.ChartProfiling.SummaryText}"
                                               Foreground="{StaticResource MutedTextSoftBrush}"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />
                                    <DataGrid ItemsSource="{Binding Workspace.ChartProfiling.Rows}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              Margin="0,10,0,0"
                                              MinHeight="170"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Stage"
                                                                Binding="{Binding Stage}"
                                                                Width="130" />
                                            <DataGridTextColumn Header="Samples"
                                                                Binding="{Binding Samples}"
                                                                Width="70" />
                                            <DataGridTextColumn Header="Total ms"
                                                                Binding="{Binding TotalMilliseconds, StringFormat={}{0:F2}}"
                                                                Width="80" />
                                            <DataGridTextColumn Header="Avg ms"
                                                                Binding="{Binding AverageMilliseconds, StringFormat={}{0:F2}}"
                                                                Width="80" />
                                            <DataGridTextColumn Header="Max ms"
                                                                Binding="{Binding MaxMilliseconds, StringFormat={}{0:F2}}"
                                                                Width="80" />
                                            <DataGridTextColumn Header="Last I/O"
                                                                Binding="{Binding LastIoSummary}"
                                                                Width="110" />
                                            <DataGridTextColumn Header="Last Event"
                                                                Binding="{Binding LastEventSummary}"
                                                                Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10"
                Margin="0,12,0,0">
            <Border Background="{StaticResource SurfaceSubtleBrush}"
                    BorderBrush="{StaticResource BorderSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,5"
                    HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Статус"
                               Foreground="{StaticResource MutedTextSoftBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0" />
                    <TextBlock Text="{Binding Workspace.Data.StatusText}"
                               Foreground="{StaticResource TextBrushTheme}"
                               FontSize="12" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
