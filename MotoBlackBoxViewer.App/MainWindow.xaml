<Window x:Class="MotoBlackBoxViewer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Moto Black Box Viewer"
        Height="920"
        Width="1500"
        MinHeight="760"
        MinWidth="1220"
        Background="#FF111827">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF1F2937" CornerRadius="10" Padding="12" Margin="0,0,0,12">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Открыть CSV" Width="130" Height="36" Margin="0,0,8,0" Click="OpenCsv_Click" />
                    <Button Content="Обновить карту" Width="130" Height="36" Margin="0,0,8,0" Click="RefreshMap_Click" />
                    <Button Content="Открыть в браузере" Width="150" Height="36" Margin="0,0,8,0" Click="OpenMap_Click" />
                    <Button Content="Очистить" Width="110" Height="36" Click="Clear_Click" />
                </StackPanel>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding CurrentFileName}" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedPointSummary}" Foreground="#FF94A3B8" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="1.45*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF1F2937" CornerRadius="10" Padding="12" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Карта маршрута" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <Border Grid.Row="1" Background="#FF0F172A" CornerRadius="8" BorderBrush="#FF334155" BorderThickness="1" ClipToBounds="True">
                        <wv2:WebView2 x:Name="MapWebView" NavigationCompleted="MapWebView_NavigationCompleted" />
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Border Background="#FF0F172A" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Воспроизведение маршрута" Foreground="White" FontSize="15" FontWeight="SemiBold" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Content="◀" Width="42" Height="34" Margin="0,0,8,0"
                                            IsEnabled="{Binding HasPoints}" Click="PrevPoint_Click" />
                                    <Button Grid.Column="1" x:Name="PlayPauseButton" Content="▶ Пуск" Width="92" Height="34" Margin="0,0,8,0"
                                            IsEnabled="{Binding HasPoints}" Click="PlayPause_Click" />
                                    <Button Grid.Column="2" Content="▶" Width="42" Height="34" Margin="0,0,12,0"
                                            IsEnabled="{Binding HasPoints}" Click="NextPoint_Click" />

                                    <Slider Grid.Column="3"
                                            Minimum="{Binding PlaybackMinimum}"
                                            Maximum="{Binding PlaybackMaximum}"
                                            Value="{Binding PlaybackPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding HasPoints}"
                                            IsSnapToTickEnabled="True"
                                            TickFrequency="1"
                                            SmallChange="1"
                                            LargeChange="1"
                                            VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="4" Text="{Binding PlaybackSummary}" Foreground="#FFE5E7EB" FontSize="13"
                                               Margin="12,0,0,0" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#FF0F172A" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                            <TextBlock Text="Выберите строку справа или двигайте ползунок — карта и графики синхронно подсветят ту же точку." 
                                       Foreground="#FFE5E7EB" FontSize="13" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Column="1" Background="#FF1F2937" BorderThickness="0" Padding="8">
                <TabItem Header="Точки">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding Points}"
                                  SelectedItem="{Binding SelectedPoint, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="#FF0F172A"
                                  Foreground="White"
                                  BorderThickness="0"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="48" />
                                <DataGridTextColumn Header="Широта" Binding="{Binding Latitude, StringFormat=F6}" Width="*" />
                                <DataGridTextColumn Header="Долгота" Binding="{Binding Longitude, StringFormat=F6}" Width="*" />
                                <DataGridTextColumn Header="Скорость" Binding="{Binding SpeedKmh, StringFormat=F1}" Width="80" />
                                <DataGridTextColumn Header="Наклон" Binding="{Binding LeanAngleDeg, StringFormat=F1}" Width="80" />
                                <DataGridTextColumn Header="AX" Binding="{Binding AccelX, StringFormat=F2}" Width="70" />
                                <DataGridTextColumn Header="AY" Binding="{Binding AccelY, StringFormat=F2}" Width="70" />
                                <DataGridTextColumn Header="AZ" Binding="{Binding AccelZ, StringFormat=F2}" Width="70" />
                                <DataGridTextColumn Header="Дистанция, м" Binding="{Binding DistanceFromStartMeters, StringFormat=F1}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Скорость">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="График скорости (км/ч)" Foreground="White" FontSize="18" Margin="0,0,0,8" />
                            <Border Background="#FF0F172A" CornerRadius="8" Padding="8">
                                <Canvas x:Name="SpeedChartCanvas" Height="300" SizeChanged="ChartCanvas_SizeChanged" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Угол наклона">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="График угла наклона (градусы)" Foreground="White" FontSize="18" Margin="0,0,0,8" />
                            <Border Background="#FF0F172A" CornerRadius="8" Padding="8">
                                <Canvas x:Name="LeanChartCanvas" Height="300" SizeChanged="ChartCanvas_SizeChanged" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Ускорения XYZ">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="График ускорений X / Y / Z" Foreground="White" FontSize="18" Margin="0,0,0,8" />
                            <Border Background="#FF0F172A" CornerRadius="8" Padding="8">
                                <Canvas x:Name="AccelChartCanvas" Height="320" SizeChanged="ChartCanvas_SizeChanged" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Статистика">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="Сводка маршрута" Foreground="White" FontSize="20" Margin="0,0,0,12" />
                            <UniformGrid Columns="2">
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Количество точек" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Statistics.PointCount}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Дистанция, м" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Statistics.TotalDistanceMeters, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Средняя скорость" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Statistics.AverageSpeedKmh, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Макс. скорость" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Statistics.MaxSpeedKmh, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Мин. угол" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Statistics.MinLeanDeg, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Макс. угол" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Statistics.MaxLeanDeg, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2" Background="#FF1F2937" CornerRadius="10" Padding="10" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="#FFE5E7EB" FontSize="14" />
        </Border>
    </Grid>
</Window>
