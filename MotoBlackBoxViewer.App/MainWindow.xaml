<Window x:Class="MotoBlackBoxViewer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:MotoBlackBoxViewer.App.Controls"
        mc:Ignorable="d"
        Title="Moto Black Box Viewer"
        Height="950"
        Width="1500"
        MinHeight="780"
        MinWidth="1240"
        Background="#FF111827">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF1F2937" CornerRadius="10" Padding="12" Margin="0,0,0,12">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Открыть CSV" Width="130" Height="36" Margin="0,0,8,0" Command="{Binding OpenCsvCommand}" />
                    <Button Content="Обновить карту" Width="130" Height="36" Margin="0,0,8,0" Command="{Binding RefreshMapCommand}" />
                    <Button Content="Открыть в браузере" Width="150" Height="36" Margin="0,0,8,0" Command="{Binding OpenMapCommand}" />
                    <Button Content="Сброс диапазона" Width="140" Height="36" Margin="0,0,8,0" Command="{Binding ResetFilterCommand}" />
                    <Button Content="Очистить" Width="110" Height="36" Command="{Binding ClearCommand}" />
                </StackPanel>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding Workspace.CurrentFileName}" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Workspace.SelectedPointSummary}" Foreground="#FF94A3B8" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="1.45*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF1F2937" CornerRadius="10" Padding="12" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Карта маршрута" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <controls:MapViewControl Grid.Row="1"
                                             RouteJson="{Binding Workspace.RouteJson}"
                                             SelectedPointIndex="{Binding Workspace.SelectedPointIndex}"
                                             RefreshVersion="{Binding Workspace.MapRefreshVersion}" />

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Border Background="#FF0F172A" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Воспроизведение маршрута" Foreground="White" FontSize="15" FontWeight="SemiBold" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Content="◀" Width="42" Height="34" Margin="0,0,8,0"
                                            IsEnabled="{Binding Workspace.HasPoints}" Command="{Binding PrevPointCommand}" />
                                    <Button Grid.Column="1" Content="{Binding Workspace.PlaybackButtonText}" Width="92" Height="34" Margin="0,0,8,0"
                                            IsEnabled="{Binding Workspace.HasPoints}" Command="{Binding TogglePlaybackCommand}" />
                                    <Button Grid.Column="2" Content="▶" Width="42" Height="34" Margin="0,0,12,0"
                                            IsEnabled="{Binding Workspace.HasPoints}" Command="{Binding NextPointCommand}" />

                                    <Slider Grid.Column="3"
                                            Minimum="{Binding Workspace.PlaybackMinimum}"
                                            Maximum="{Binding Workspace.PlaybackMaximum}"
                                            Value="{Binding Workspace.PlaybackPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding Workspace.HasPoints}"
                                            IsSnapToTickEnabled="True"
                                            TickFrequency="1"
                                            SmallChange="1"
                                            LargeChange="1"
                                            VerticalAlignment="Center" />

                                    <ComboBox Grid.Column="4"
                                              Width="86"
                                              Height="30"
                                              Margin="12,0,0,0"
                                              ItemsSource="{Binding Workspace.PlaybackSpeedOptions}"
                                              SelectedItem="{Binding Workspace.SelectedPlaybackSpeed, Mode=TwoWay}"
                                              DisplayMemberPath="Label"
                                              IsEnabled="{Binding Workspace.HasPoints}"
                                              VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="5"
                                               Text="{Binding Workspace.PlaybackSummary}"
                                               Foreground="#FFE5E7EB"
                                               FontSize="13"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <TextBlock Text="{Binding Workspace.PlaybackSpeedSummary}" Foreground="#FF94A3B8" FontSize="12" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="#FF0F172A" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                            <StackPanel>
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="Фильтр диапазона точек" Foreground="White" FontSize="15" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                    <Button Content="Сбросить" Width="90" Height="28" DockPanel.Dock="Right" Command="{Binding ResetFilterCommand}" />
                                </DockPanel>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="От точки" Foreground="#FFE5E7EB" VerticalAlignment="Center" />
                                    <Slider Grid.Column="1"
                                            Minimum="{Binding Workspace.FilterMinimum}"
                                            Maximum="{Binding Workspace.FilterMaximum}"
                                            Value="{Binding Workspace.FilterStartIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding Workspace.HasSourceData}"
                                            IsSnapToTickEnabled="True"
                                            TickFrequency="1"
                                            SmallChange="1"
                                            LargeChange="10"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding Workspace.FilterStartIndex}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="До точки" Foreground="#FFE5E7EB" VerticalAlignment="Center" />
                                    <Slider Grid.Column="1"
                                            Minimum="{Binding Workspace.FilterMinimum}"
                                            Maximum="{Binding Workspace.FilterMaximum}"
                                            Value="{Binding Workspace.FilterEndIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding Workspace.HasSourceData}"
                                            IsSnapToTickEnabled="True"
                                            TickFrequency="1"
                                            SmallChange="1"
                                            LargeChange="10"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding Workspace.FilterEndIndex}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>

                                <TextBlock Text="{Binding Workspace.FilterSummary}" Foreground="#FF94A3B8" FontSize="12" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="#FF0F172A" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                            <TextBlock Text="Выберите строку справа, двигайте ползунок или ограничьте диапазон — карта и графики синхронно покажут только нужный участок маршрута."
                                       Foreground="#FFE5E7EB" FontSize="13" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Column="1" Background="#FF1F2937" BorderThickness="0" Padding="8">
                <TabItem Header="Точки">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding Workspace.Points}"
                                  SelectedItem="{Binding Workspace.SelectedPoint, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="#FF0F172A"
                                  Foreground="White"
                                  BorderThickness="0"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="48" />
                                <DataGridTextColumn Header="Широта" Binding="{Binding Latitude, StringFormat=F6}" Width="*" />
                                <DataGridTextColumn Header="Долгота" Binding="{Binding Longitude, StringFormat=F6}" Width="*" />
                                <DataGridTextColumn Header="Скорость" Binding="{Binding SpeedKmh, StringFormat=F1}" Width="80" />
                                <DataGridTextColumn Header="Наклон" Binding="{Binding LeanAngleDeg, StringFormat=F1}" Width="80" />
                                <DataGridTextColumn Header="AX" Binding="{Binding AccelX, StringFormat=F2}" Width="70" />
                                <DataGridTextColumn Header="AY" Binding="{Binding AccelY, StringFormat=F2}" Width="70" />
                                <DataGridTextColumn Header="AZ" Binding="{Binding AccelZ, StringFormat=F2}" Width="70" />
                                <DataGridTextColumn Header="Дистанция, м" Binding="{Binding DistanceFromStartMeters, StringFormat=F1}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Скорость">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="График скорости (км/ч)" Foreground="White" FontSize="18" Margin="0,0,0,8" />
                            <Border Background="#FF0F172A" CornerRadius="8" Padding="8">
                                <controls:LineChartControl Values="{Binding Workspace.SpeedSeries}"
                                                           SelectedIndex="{Binding Workspace.PlaybackPosition}"
                                                           Unit="км/ч"
                                                           SeriesLabel="Скорость"
                                                           LineColorHex="#38BDF8" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Угол наклона">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="График угла наклона (градусы)" Foreground="White" FontSize="18" Margin="0,0,0,8" />
                            <Border Background="#FF0F172A" CornerRadius="8" Padding="8">
                                <controls:LineChartControl Values="{Binding Workspace.LeanSeries}"
                                                           SelectedIndex="{Binding Workspace.PlaybackPosition}"
                                                           Unit="°"
                                                           SeriesLabel="Наклон"
                                                           LineColorHex="#A78BFA" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Ускорения XYZ">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="График ускорений X / Y / Z" Foreground="White" FontSize="18" Margin="0,0,0,8" />
                            <Border Background="#FF0F172A" CornerRadius="8" Padding="8">
                                <controls:MultiLineChartControl Series="{Binding Workspace.AccelSeries}"
                                                                SelectedIndex="{Binding Workspace.PlaybackPosition}"
                                                                Unit="ед." />
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Статистика">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock Text="Сводка маршрута / диапазона" Foreground="White" FontSize="20" Margin="0,0,0,12" />
                            <UniformGrid Columns="2">
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Количество точек" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Workspace.Statistics.PointCount}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Дистанция, м" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Workspace.Statistics.TotalDistanceMeters, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Средняя скорость" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Workspace.Statistics.AverageSpeedKmh, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Макс. скорость" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Workspace.Statistics.MaxSpeedKmh, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Мин. угол" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Workspace.Statistics.MinLeanDeg, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="4" Padding="12" Background="#FF0F172A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="Макс. угол" Foreground="#FF94A3B8" />
                                        <TextBlock Text="{Binding Workspace.Statistics.MaxLeanDeg, StringFormat=F1}" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2" Background="#FF1F2937" CornerRadius="10" Padding="10" Margin="0,12,0,0">
            <TextBlock Text="{Binding Workspace.StatusText}" Foreground="#FFE5E7EB" FontSize="14" />
        </Border>
    </Grid>
</Window>
